meta {
  name: List anime - Current season
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/list/anime/season?cat=TV
  body: none
  auth: inherit
}

params:query {
  cat: TV
}

settings {
  encodeUrl: true
}

docs {
  ## Query params

  | Param | Description |
  |-------|-------------|
  | cat   | TV, TV_new, TV_continuing, ONA, OVA, Movie, Special |
}
